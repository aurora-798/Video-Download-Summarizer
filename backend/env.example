# Copy this file to `.env` (in the same directory) and fill in your keys:
#   cp backend/env.example backend/.env
# .env is gitignored / cursorignored, env.example is checked in.

# --- LLM (OpenAI-compatible Chat Completions) -------------------------
# Required for /api/summarize. Defaults below target DeepSeek.
OPENAI_API_KEY=sk-your-deepseek-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# Other compatible providers (pick one set):
# Moonshot Kimi
#   OPENAI_BASE_URL=https://api.moonshot.cn
#   OPENAI_MODEL=moonshot-v1-32k
# Aliyun Qwen
#   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
#   OPENAI_MODEL=qwen-plus
# SiliconFlow
#   OPENAI_BASE_URL=https://api.siliconflow.cn
#   OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct
# OpenAI
#   OPENAI_BASE_URL=https://api.openai.com
#   OPENAI_MODEL=gpt-4o-mini


# --- Speech-to-text (Whisper) -----------------------------------------
# WHISPER_BACKEND=local (default) — uses faster-whisper on this machine.
# WHISPER_BACKEND=api             — calls an OpenAI-compatible /audio/transcriptions endpoint.
WHISPER_BACKEND=local

# Local backend: model size & device
#   model:    tiny | base | small | medium | large-v3   (default: base, ~70MB)
#   device:   cpu | cuda | auto                          (default: cpu)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
# compute_type: int8 (cpu) / float16 (gpu); leave unset for auto.
# WHISPER_COMPUTE_TYPE=int8

# Remote API backend (only used when WHISPER_BACKEND=api)
#   SiliconFlow example:
#     WHISPER_BASE_URL=https://api.siliconflow.cn/v1
#     WHISPER_API_KEY=sk-your-siliconflow-key
#     WHISPER_API_MODEL=FunAudioLLM/SenseVoiceSmall
#   OpenAI example:
#     WHISPER_BASE_URL=https://api.openai.com/v1
#     WHISPER_API_KEY=sk-your-openai-key
#     WHISPER_API_MODEL=whisper-1
